# T-Invest API токен для ордеров (sandbox или боевой в зависимости от SANDBOX=)
TINKOFF_TOKEN=your_tinkoff_token_here

# Боевой токен только для чтения рыночных данных (стрим котировок).
# Нужен когда SANDBOX=true, т.к. sandbox не транслирует рыночные данные.
# Если не задан — используется TINKOFF_TOKEN.
TINKOFF_MARKET_TOKEN=your_real_tinkoff_token_here

# MySQL: mysql+pymysql://user:password@host:port/database
MYSQL_URL=mysql+pymysql://trading_user:trading_pass@localhost:3306/trading_bot

# Flask
WEB_SECRET_KEY=change-me-to-random-secret-key-32chars
WEB_USERNAME=admin
WEB_PASSWORD=your_dashboard_password
WEB_HOST=127.0.0.1
WEB_PORT=5000

# Риск-менеджмент: лимит дневных убытков в % от счёта (0.01 = 1%)
DAILY_LOSS_LIMIT_PCT=0.01
# Fallback лимит в рублях — если стоимость счёта ещё не загружена при старте
DAILY_LOSS_LIMIT_RUB=-500.0

# Telegram уведомления (запуск бота, начало торгов, открытие/закрытие сделок)
# Токен получить у @BotFather, chat_id — у @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Логирование: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Sandbox режим: true = тестовые ордера, false = реальная торговля
SANDBOX=true

# ClickHouse для хранения рыночных данных (стакан + тики) вместо MySQL.
# Если CLICKHOUSE_HOST не задан — данные пишутся в MySQL как раньше.
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=trading_bot
